test compile precise-output
target x86_64 has_avx512f has_avx512bw has_avx512dq has_avx512vl has_avx512vp2intersect

;; x86_simd_vp2intersect_mask: per-lane set-membership mask.
;;
;; Lowering: VP2INTERSECTD/Q writing the fixed k6/k7 pair (both halves are
;; fixed-reg defs; the b-side mask in k7 is a modeled dead def), then
;; VPMOVM2D/Q expands the a-side mask (k6) to a 0/-1 vector.

function %vp2intersect_i32x16(i32x16, i32x16) -> i32x16 {
block0(v0: i32x16, v1: i32x16):
    v2 = x86_simd_vp2intersect_mask v0, v1
    return v2
}

; VCode:
;   pushq %rbp
;   movq %rsp, %rbp
; block0:
;   vp2intersectd %k6/%k7 (pair %k6/%k7), %zmm0, %zmm1
;   vpmovm2d %k6, %zmm0
;   movq %rbp, %rsp
;   popq %rbp
;   retq
;
; Disassembled:
; block0: ; offset 0x0
;   pushq %rbp
;   movq %rsp, %rbp
; block1: ; offset 0x4

function %vp2intersect_i64x8(i64x8, i64x8) -> i64x8 {
block0(v0: i64x8, v1: i64x8):
    v2 = x86_simd_vp2intersect_mask v0, v1
    return v2
}

