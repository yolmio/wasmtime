;; The vp2intersect result feeding a k-mask consumer (bitselect) exercises
;; interaction between the fixed k6/k7 pair defs and allocatable k-mask
;; temps in the surrounding code.
function %vp2intersect_bitselect_i32x16(i32x16, i32x16, i32x16, i32x16) -> i32x16 {
block0(v0: i32x16, v1: i32x16, v2: i32x16, v3: i32x16):
    v4 = x86_simd_vp2intersect_mask v0, v1
    v5 = bitselect v4, v2, v3
    return v5
}

