;   movq %rsp, %rbp
; block1: ; offset 0x4

;; Two intersections back to back: k6/k7 must be reusable immediately.
function %vp2intersect_twice_i64x8(i64x8, i64x8, i64x8) -> i64x8 {
block0(v0: i64x8, v1: i64x8, v2: i64x8):
    v3 = x86_simd_vp2intersect_mask v0, v1
    v4 = x86_simd_vp2intersect_mask v0, v2
    v5 = band v3, v4
    return v5
}

