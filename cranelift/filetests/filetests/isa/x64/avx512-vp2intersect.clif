;; Semi-join shape: filter probe lanes by build-side membership.
;; result = probe & membership_mask(probe, build)
function %semi_join_filter_i32x16(i32x16, i32x16) -> i32x16 {
block0(v0: i32x16, v1: i32x16):
    v2 = x86_simd_vp2intersect_mask v0, v1
    v3 = band v0, v2
    return v3
}

