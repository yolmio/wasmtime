;; b-side mask by swapping the operands.
function %vp2intersect_swapped_i32x16(i32x16, i32x16) -> i32x16 {
block0(v0: i32x16, v1: i32x16):
    v2 = x86_simd_vp2intersect_mask v1, v0
    return v2
}

