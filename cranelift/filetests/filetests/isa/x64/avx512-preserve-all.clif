test compile precise-output
set enable_simd32=true
target x86_64 has_avx512f has_avx512bw has_avx512dq has_avx512vl

;; `preserve_all` under AVX-512: every register the body clobbers (including
;; the clobber sets of any calls it makes) must be saved and restored, and
;; the saves must cover the *full* architectural state:
;;   - Float-class saves must be 512-bit (`vmovdqu32` of the whole ZMM
;;     register, 64 bytes each), not 128-bit `movdqu` -- a 128-bit save would
;;     silently drop the upper bits of a caller's live ZMM value;
;;   - xmm16-xmm31 must be included;
;;   - the k-mask registers k2-k7 must be saved with `kmovq`.
;;
;; Conversely, a `preserve_all` function that never touches AVX-512 state
;; (no calls, no vector ops) must not save any of it: the save list is driven
;; by the function's actual regalloc clobbers.

;; A trampoline: calling a system_v callee clobbers (abstractly) all
;; caller-saved registers, so the preserve_all prologue must save the full
;; ZMM state of xmm0-31 plus k2-k7.
function %preserve_all_trampoline(i64) preserve_all {
    fn0 = %libcall(i64) system_v
block0(v0: i64):
    call fn0(v0)
    return
}

