;; A leaf preserve_all function whose body uses 512-bit ops and k-registers
;; (icmp on i32x16 goes through VPCMPD -> k-reg -> VPMOVM2D): the registers
;; it actually clobbers -- and only those -- must be saved, with full-width
;; ZMM saves and a kmovq save for the k-register.
function %preserve_all_avx512_body(i64, i64) preserve_all {
block0(v0: i64, v1: i64):
    v2 = load.i32x16 v0
    v3 = load.i32x16 v1
    v4 = icmp eq v2, v3
    store v4, v0
    return
}

