;; A leaf preserve_all function under AVX-512 flags that uses no vector ops
;; at all: it must not save k-registers or any xmm state it does not clobber.
function %preserve_all_scalar_only(i64, i64) preserve_all {
block0(v0: i64, v1: i64):
    v2 = iadd v0, v1
    store v2, v0
    return
}

