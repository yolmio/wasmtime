;; Negative fusion lock: a byte-granular vconst mask must NOT fuse; expect a
;; plain VPADDD followed by the bitwise VPTERNLOGD select.
function %fusion_iadd_i32x16_bytemask(i32x16, i32x16, i32x16) -> i32x16 {
block0(v0: i32x16, v1: i32x16, v2: i32x16):
    v3 = vconst.i32x16 [0x00ff00ff 0x00ff00ff 0x00ff00ff 0x00ff00ff 0x00ff00ff 0x00ff00ff 0x00ff00ff 0x00ff00ff 0x00ff00ff 0x00ff00ff 0x00ff00ff 0x00ff00ff 0x00ff00ff 0x00ff00ff 0x00ff00ff 0x00ff00ff]
    v4 = iadd v0, v1
    v5 = bitselect v3, v4, v2
    return v5
}

