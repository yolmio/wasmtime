;; Positive fusion lock: an icmp-produced mask still fuses
;; bitselect(mask, iadd(x, y), passthru) into a single merge-masked VPADDD.
function %fusion_iadd_i32x16_icmp_mask(i32x16, i32x16, i32x16, i32x16, i32x16) -> i32x16 {
block0(v0: i32x16, v1: i32x16, v2: i32x16, v3: i32x16, v4: i32x16):
    v5 = icmp eq v0, v1
    v6 = iadd v2, v3
    v7 = bitselect v5, v6, v4
    return v7
}

