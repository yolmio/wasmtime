;; bitcast.i64x8 of an fcmp on f32x16: the comparison's lanes are 32-bit,
;; the bitselect's are 64-bit, so this is a byte mask but not a 64-bit lane
;; mask -> bitwise VPTERNLOGQ, never VPBLENDMQ.
function %bitselect_i64x8_bitcast_fcmp(f32x16, f32x16, i64x8, i64x8) -> i64x8 {
block0(v0: f32x16, v1: f32x16, v2: i64x8, v3: i64x8):
    v4 = fcmp eq v0, v1
    v5 = bitcast.i64x8 little v4
    v6 = bitselect v5, v2, v3
    return v6
}

