;   vpmovd2m %zmm5, %k4
;   vpblendmd %zmm0, %zmm1, %zmm0 {%k4}
;   movq %rbp, %rsp
;   popq %rbp
;   retq
;
; Disassembled:
; block0: ; offset 0x0
;   pushq %rbp
;   movq %rsp, %rbp
; block1: ; offset 0x4
;   vmovdqu32 0x12(%rip), %zmm5
;   vpmovd2m %zmm5, %k4
;   vpblendmd %zmm0, %zmm1, %zmm0 {%k4}
;   movq %rbp, %rsp
;   popq %rbp
;   retq
;   addb %bh, %bh

;; vconst condition whose BYTES are all 0x00/0xFF but whose 32-bit lanes are
;; NOT uniform (0x00ff00ff): must NOT take the sign-bit-sampling blend; must
;; lower to the bitwise VPTERNLOGD.
function %bitselect_i32x16_vconst_bytemask(i32x16, i32x16) -> i32x16 {
block0(v0: i32x16, v1: i32x16):
    v2 = vconst.i32x16 [0x00ff00ff 0x00ff00ff 0x00ff00ff 0x00ff00ff 0x00ff00ff 0x00ff00ff 0x00ff00ff 0x00ff00ff 0x00ff00ff 0x00ff00ff 0x00ff00ff 0x00ff00ff 0x00ff00ff 0x00ff00ff 0x00ff00ff 0x00ff00ff]
    v3 = bitselect v2, v0, v1
    return v3
}

