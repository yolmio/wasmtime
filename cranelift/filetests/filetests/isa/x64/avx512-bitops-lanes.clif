;; =============================================================================
;; Lane-mask strictness regressions (all_lanes_ones_or_zeros)
;; =============================================================================
;; The whole-lane VPBLENDMD/Q and masked-fusion lowerings sample only each
;; lane's sign bit (VPMOVD2M/Q), so they may fire only when the condition is
;; provably a LANE mask at the bitselect type's granularity. Byte-granular
;; masks (0x00/0xFF bytes, mixed within a lane) and lane-count-changing
;; bitcasts of comparisons must take the bitwise VPTERNLOG path.

;; vconst condition whose LANES are uniformly all-ones/all-zeros: the
;; whole-lane blend is still legal and must be used.
function %bitselect_i32x16_vconst_lanemask(i32x16, i32x16) -> i32x16 {
block0(v0: i32x16, v1: i32x16):
    v2 = vconst.i32x16 [0xffffffff 0 0xffffffff 0 0xffffffff 0 0xffffffff 0 0xffffffff 0 0xffffffff 0 0xffffffff 0 0xffffffff 0]
    v3 = bitselect v2, v0, v1
    return v3
}

