test compile precise-output
target x86_64 has_avx512f has_avx512bw has_avx512dq has_avx512vl

;; Bit-exact 512-bit bitselect / swizzle / float lane-access lowerings.
;;
;; - bitselect with a comparison condition locks the VPMOVD2M/Q + VPBLENDMD/Q
;;   whole-lane blend path (valid because comparison lanes are all-ones or
;;   all-zeros).
;; - bitselect with an arbitrary condition locks the bitwise VPTERNLOGD/Q
;;   (imm8=0xCA, A?B:C) path.
;; - swizzle locks the VPCMPUD/Q + VPERMD/Q + zero-blend sequence which
;;   implements CLIF's out-of-range-index-produces-zero semantics.
;; - extractlane/insertlane on F32X16/F64X8 lock the XMM-only float paths
;;   (VEXTRACTF32X4/VEXTRACTF64X2 + shuffles); no GPR may appear.

;; Comparison-produced condition: whole-lane blend is legal.
function %bitselect_i32x16_cmp(i32x16, i32x16, i32x16, i32x16) -> i32x16 {
block0(v0: i32x16, v1: i32x16, v2: i32x16, v3: i32x16):
    v4 = icmp eq v0, v1
    v5 = bitselect v4, v2, v3
    return v5
}

; VCode:
;   pushq %rbp
;   movq %rsp, %rbp
; block0:
;   vpcmpd $0x0, %zmm1, %zmm0, %k7
;   vpmovm2d %k7, %zmm0
;   vpmovd2m %zmm0, %k7
;   vpblendmd %zmm2, %zmm3, %zmm0 {%k7}
;   movq %rbp, %rsp
;   popq %rbp
;   retq
;
; Disassembled:
; block0: ; offset 0x0
;   pushq %rbp
;   movq %rsp, %rbp
; block1: ; offset 0x4
;   vpcmpeqd %zmm1, %zmm0, %k7
;   vpmovm2d %k7, %zmm0
;   vpmovd2m %zmm0, %k7
;   vpblendmd %zmm2, %zmm3, %zmm0 {%k7}
;   movq %rbp, %rsp
;   popq %rbp
;   retq

;; Arbitrary condition: must take the bitwise VPTERNLOG path.
function %bitselect_i32x16_raw(i32x16, i32x16, i32x16) -> i32x16 {
block0(v0: i32x16, v1: i32x16, v2: i32x16):
    v3 = bitselect v0, v1, v2
    return v3
}

