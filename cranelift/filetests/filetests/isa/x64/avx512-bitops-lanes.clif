function %bitselect_i64x8_cmp(i64x8, i64x8, i64x8, i64x8) -> i64x8 {
block0(v0: i64x8, v1: i64x8, v2: i64x8, v3: i64x8):
    v4 = icmp eq v0, v1
    v5 = bitselect v4, v2, v3
    return v5
}

