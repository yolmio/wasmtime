;; Positive lock for the same-lane-count bitcast arm: the canonical float
;; mask pattern bitcast.f32x16(fcmp on f32x16) keeps the masked VADDPS
;; fusion (32-bit lanes on both sides of the bitcast).
function %fusion_fadd_f32x16_bitcast_fcmp(f32x16, f32x16, f32x16, f32x16, f32x16) -> f32x16 {
block0(v0: f32x16, v1: f32x16, v2: f32x16, v3: f32x16, v4: f32x16):
    v5 = fcmp gt v0, v1
    v6 = bitcast.f32x16 little v5
    v7 = fadd v2, v3
    v8 = bitselect v6, v7, v4
    return v8
}

