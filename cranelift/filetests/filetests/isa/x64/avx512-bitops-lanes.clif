;; 64-bit lanes of 0x00000000ffffffff: uniform at 32-bit granularity but not
;; at the bitselect type's 64-bit granularity -> bitwise VPTERNLOGQ.
function %bitselect_i64x8_vconst_bytemask(i64x8, i64x8) -> i64x8 {
block0(v0: i64x8, v1: i64x8):
    v2 = vconst.i64x8 [0x00000000ffffffff 0x00000000ffffffff 0x00000000ffffffff 0x00000000ffffffff 0x00000000ffffffff 0x00000000ffffffff 0x00000000ffffffff 0x00000000ffffffff]
    v3 = bitselect v2, v0, v1
    return v3
}

