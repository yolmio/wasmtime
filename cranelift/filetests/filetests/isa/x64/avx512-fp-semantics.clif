test compile precise-output
target x86_64 has_avx512f has_avx512bw has_avx512dq has_avx512vl

;; CLIF-correct 512-bit fmin/fmax (NaN => quiet NaN, fmin(+0,-0) = -0,
;; fmax(-0,+0) = +0) and fcvt_to_sint_sat (NaN => 0, positive overflow =>
;; INT_MAX, negative overflow => INT_MIN).

function %fmin_f32x16(f32x16, f32x16) -> f32x16 {
block0(v0: f32x16, v1: f32x16):
    v2 = fmin v0, v1
    return v2
}

