;   movq %rsp, %rbp
; block1: ; offset 0x4
;   vminps %zmm1, %zmm0, %zmm3
;   vminps %zmm0, %zmm1, %zmm5
;   vpord %zmm5, %zmm3, %zmm7
;   vcmpunordps %zmm1, %zmm0, %k2
;   movl $0x7fc00000, %r11d
;   movd %r11d, %xmm0
;   vpbroadcastd %xmm0, %zmm0
;   vpblendmd %zmm0, %zmm7, %zmm0 {%k2}
;   movq %rbp, %rsp
;   popq %rbp
;   retq

function %fmax_f32x16(f32x16, f32x16) -> f32x16 {
block0(v0: f32x16, v1: f32x16):
    v2 = fmax v0, v1
    return v2
