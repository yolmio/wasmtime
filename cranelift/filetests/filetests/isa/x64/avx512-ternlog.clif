;   movq %rbp, %rsp
;   popq %rbp
;   retq
;
; Disassembled:
; block0: ; offset 0x0
;   pushq %rbp
;   movq %rsp, %rbp
; block1: ; offset 0x4
;   vpternlogd $0x96, %zmm1, %zmm0, %zmm0
;   movq %rbp, %rsp
;   popq %rbp
;   retq

;; (a & a) | c: A and B are the same register.
function %and_aa_or_c_i64x8(i64x8, i64x8) -> i64x8 {
block0(v0: i64x8, v1: i64x8):
    v2 = band v0, v0
    v3 = bor v2, v1
    return v3
}

