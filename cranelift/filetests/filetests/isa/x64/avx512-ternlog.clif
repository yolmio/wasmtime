;; ---------------------------------------------------------------------------
;; Value reused outside the fused tree: the tied operand (v0) is live after
;; the vpternlog, forcing regalloc to preserve it.
;; ---------------------------------------------------------------------------

function %xor3_tied_live_after_i32x16(i32x16, i32x16, i32x16) -> i32x16 {
block0(v0: i32x16, v1: i32x16, v2: i32x16):
    v3 = bxor v0, v1
    v4 = bxor v3, v2
    v5 = iadd v4, v0
    return v5
}

