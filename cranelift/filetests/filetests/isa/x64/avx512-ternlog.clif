;; ---------------------------------------------------------------------------
;; Aliased inputs (tie/RMW hazard cases): the same SSA value feeds two of the
;; three VPTERNLOG inputs, including the tied first operand.
;; ---------------------------------------------------------------------------

;; a ^ a ^ c: A and B are the same register.
function %xor_aac_i32x16(i32x16, i32x16) -> i32x16 {
block0(v0: i32x16, v1: i32x16):
    v2 = bxor v0, v0
    v3 = bxor v2, v1
    return v3
}

; VCode:
;   pushq %rbp
