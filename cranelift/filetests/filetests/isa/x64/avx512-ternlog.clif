test compile precise-output
target x86_64 has_avx512f has_avx512bw has_avx512dq has_avx512vl

;; VPTERNLOG 3-input boolean fusion: each of the fused shapes below must
;; lower to a SINGLE vpternlogd/vpternlogq with the documented imm8.
;;
;; imm8 truth tables (A = first/tied operand = 0xF0, B = 0xCC, C = 0xAA):
;;   A^B^C       = 0x96
;;   A&B&C       = 0x80
;;   A|B|C       = 0xFE
;;   (A&B)|C     = 0xEA
;;   (A|B)&C     = 0xA8
;;
;; I64X8 uses vpternlogq; I32X16/I16X32/I8X64 use vpternlogd (bitwise ops
;; are lane-size agnostic).

;; ---------------------------------------------------------------------------
;; xor3, both associations
;; ---------------------------------------------------------------------------

function %xor3_left_i32x16(i32x16, i32x16, i32x16) -> i32x16 {
block0(v0: i32x16, v1: i32x16, v2: i32x16):
    v3 = bxor v0, v1
    v4 = bxor v3, v2
    return v4
}

; VCode:
;   pushq %rbp
;   movq %rsp, %rbp
; block0:
;   vpternlogd $0x96, %zmm2, %zmm1, %zmm0
;   movq %rbp, %rsp
;   popq %rbp
;   retq
;
; Disassembled:
; block0: ; offset 0x0
;   pushq %rbp
;   movq %rsp, %rbp
; block1: ; offset 0x4
;   vpternlogd $0x96, %zmm2, %zmm1, %zmm0
;   movq %rbp, %rsp
;   popq %rbp
;   retq

function %xor3_right_i32x16(i32x16, i32x16, i32x16) -> i32x16 {
block0(v0: i32x16, v1: i32x16, v2: i32x16):
    v3 = bxor v1, v2
    v4 = bxor v0, v3
    return v4
}

