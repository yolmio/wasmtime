;   movq %rbp, %rsp
;   popq %rbp
;   retq

;; (a | b) & a: A (tied) is also C.
function %orand_aba_i32x16(i32x16, i32x16) -> i32x16 {
block0(v0: i32x16, v1: i32x16):
    v2 = bor v0, v1
    v3 = band v2, v0
    return v3
}

